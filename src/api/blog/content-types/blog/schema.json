{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "description": {
      "type": "text"
    },
    "date": {
      "type": "date"
    },
    "readTime": {
      "type": "integer"
    },
    "category": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Blog",
        "Pulse"
      ]
    },
    "page_template": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::blog-template.blog-template"
    }
  }
}
